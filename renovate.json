{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "customManagers:dockerfileVersions"
  ],
  "enabledManagers": [
    "asdf",
    "bundler",
    "circleci",
    "docker-compose",
    "dockerfile",
    "npm"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "minimumReleaseAge": "14 days",
  "postUpdateOptions": [
    "bundlerConservative",
    "yarnDedupeHighest"
  ],
  "packageRules": [
    {
      "description": "Ensure that only the specified release of the Postgres Docker Image is used.",
      "matchDatasources": [
        "docker"
      ],
      "enabled": false,
      "matchPackageNames": [
        "/postgres/"
      ]
    },
    {
      "description": "Ensure that the latest stable releases of Ruby Gems are used.",
      "matchManagers": [
        "bundler"
      ],
      "rangeStrategy": "update-lockfile"
    },
    {
      "description": "Group major Rails framework updates together.",
      "matchManagers": [
        "bundler"
      ],
      "matchPackagePatterns": ["^rails$", "^action", "^active", "^railties$"],
      "matchUpdateTypes": ["major"],
      "groupName": "Ruby on Rails Ecosystem"
    }
  ],
  "prHourlyLimit": 3
}
